{
  "name": "@paperclipai/adapter-agrenting",
  "version": "0.2.0",
  "description": "Paperclip adapter for Agrenting — remote AI agent orchestration via the Agrenting platform",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    }
  },
  "files": [
    "dist",
    "server",
    "ui",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint server/src/ ui/src/"
  },
  "keywords": [
    "paperclip",
    "agrenting",
    "adapter",
    "ai-agents",
    "cacp"
  ],
  "author": "AgRenting",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaalipro/paperclip-agrenting"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
